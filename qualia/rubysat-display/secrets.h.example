// secrets.h.example — copy to secrets.h and fill in. secrets.h is GITIGNORED.
//
//   cp secrets.h.example secrets.h
//   $EDITOR secrets.h
//
// Two Wi-Fi networks are supported: home first, then the phone hotspot as a
// fallback (the firmware tries WIFI_SSID for ~12s, then WIFI_SSID2).

#ifndef RUBYSAT_SECRETS_H
#define RUBYSAT_SECRETS_H

// --- Home network ---
#define WIFI_SSID   "your-home-ssid"
#define WIFI_PASS   "your-home-password"

// --- Hotspot fallback (leave SSID2 as "" to disable) ---
#define WIFI_SSID2  "your-hotspot-ssid"
#define WIFI_PASS2  "your-hotspot-password"

// --- Ruby Pi (rubysat server) ---
// mDNS "ruby.local" is tried first; this static IP is the fallback.
#define RUBY_FALLBACK_IP  "192.168.2.180"
#define RUBY_PORT         7878

#endif  // RUBYSAT_SECRETS_H
